# Groq API key — powers the plain-English brief rewrites and the chat terminal.
# Get one free at https://console.groq.com/keys
# The app runs WITHOUT a key (it falls back to the curated summaries), but the
# LLM rewrites and chat only work once this is set.
GROQ_API_KEY=

# Optional: override the default Groq model.
GROQ_MODEL=llama-3.3-70b-versatile
